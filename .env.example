# Supabase — https://supabase.com/dashboard
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# TMDB — https://www.themoviedb.org/settings/api
TMDB_API_KEY=your-tmdb-api-key

# OpenAI — https://platform.openai.com/api-keys (pentru semantic search)
OPENAI_API_KEY=your-openai-api-key

# Secret pentru protejarea endpoint-ului de seed (/api/admin/seed-embeddings)
SEED_SECRET=your-random-secret

# Feature flags — set to "true" to enable, omit or set to anything else to disable
FEATURE_SEMANTIC_SEARCH=true
